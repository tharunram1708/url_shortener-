# Default local mode uses SQLite.
DB_ENGINE=sqlite

# MySQL mode:
# DB_ENGINE=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_DATABASE=url_shortener

# You can also skip the variables above and use one full SQLAlchemy URL:
# DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/url_shortener

SECRET_KEY=change-this-secret-key-before-production
